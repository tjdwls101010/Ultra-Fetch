#!/usr/bin/env bash
# Launcher for the ultra-fetch CLI.
#
# Resolves the dedicated venv, provisions it on first use, and execs the CLI.
# The venv lives outside the repo so it survives skill edits and is never
# committed; this path is duplicated in ultra_fetch/config.py (VENV_DIR) and the
# two must agree.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
VENV="${XDG_CACHE_HOME:-$HOME/.cache}/ultra-fetch/venv"
PY="$VENV/bin/python"

if [[ ! -x "$PY" ]]; then
  echo "ultra-fetch: first run -- provisioning a dedicated environment." >&2
  echo "ultra-fetch: this downloads several hundred MB of browser engines once, then never again." >&2

  if command -v uv >/dev/null 2>&1; then
    uv venv "$VENV" --python 3.12 >&2
    uv pip install --python "$PY" -r "$SCRIPT_DIR/requirements.txt" >&2
  else
    python3 -m venv "$VENV" >&2
    "$PY" -m pip install --quiet --upgrade pip >&2
    "$PY" -m pip install -r "$SCRIPT_DIR/requirements.txt" >&2
  fi

  # Browser engines for both stacks. Failure here is exit 2 (setup needed)
  # rather than a crash, so the caller gets an actionable code instead of a
  # traceback from the first real fetch.
  if ! PYTHONPATH="$SCRIPT_DIR" "$PY" -m ultra_fetch setup --browsers >&2; then
    echo "ultra-fetch: browser setup failed; run 'ultra-fetch setup --browsers' to retry." >&2
    exit 2
  fi
fi

exec env PYTHONPATH="$SCRIPT_DIR" "$PY" -m ultra_fetch "$@"
